# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class

# PyInstaller build output (Keepy.spec is intentionally NOT ignored - we ship it)
build/
dist/

# Packaging / distribution metadata
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Editor / OS cruft
.idea/
.vscode/
.DS_Store
Thumbs.db

# Keepy writes its per-action custom sounds to ~/.keepy/sounds.json in the user's
# home directory (NOT inside the repo), so there is nothing to ignore here for
# runtime config. keepy.py is the only source file and is always tracked.
keepy.png
